# Required: Your OpenRouter API key (get one at https://openrouter.ai)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Optional: LLM model to use (must be a free model with :free suffix)
LLM_MODEL=google/gemma-3-27b-it:free

# Optional: Frontend URL for CORS (default: http://localhost:3001)
FRONTEND_URL=http://localhost:3001

# Optional: Port to listen on (default: 3000)
PORT=3000

# Optional: System prompt sent to the model on every request
SYSTEM_PROMPT=You are a helpful assistant.

# Optional: SQLite database file path (default: chat.db)
DB_PATH=chat.db
